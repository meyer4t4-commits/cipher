# ============================================================
# ORCHID - Environment Configuration
# Copy this to .env and fill in your values
# ============================================================

# --- Application ---
APP_NAME=orchid
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=change-this-to-a-random-64-char-string

# --- LLM Providers (via LiteLLM) ---
# Primary: Anthropic Claude (best reasoning)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Secondary: Groq (fast Llama inference)
GROQ_API_KEY=gsk_xxxxx

# Optional: OpenAI (if needed for specific tasks)
OPENAI_API_KEY=sk-xxxxx

# Optional: Local Ollama (when running local models)
OLLAMA_BASE_URL=http://localhost:11434

# --- Default Model Routing ---
DEFAULT_MODEL=claude-sonnet-4-20250514
REASONING_MODEL=claude-sonnet-4-20250514
FAST_MODEL=groq/llama-3.3-70b-versatile
LOCAL_MODEL=ollama/llama3.3
CODE_MODEL=claude-sonnet-4-20250514

# --- Database ---
DATABASE_URL=sqlite:///./data/orchid.db
CHROMA_PERSIST_DIR=./data/chroma

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_ALLOWED_USERS=your-telegram-user-id

# --- Redis (for Celery task queue) ---
REDIS_URL=redis://localhost:6379/0

# --- ElevenLabs (Phase 2 - Voice) ---
ELEVENLABS_API_KEY=your-elevenlabs-key

# --- Payments ---
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
BTCPAY_URL=https://your-btcpay-instance.com
BTCPAY_API_KEY=your-btcpay-key

# --- Security ---
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440
