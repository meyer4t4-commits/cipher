# ============================================================
# Cipher - Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# --- Application ---
APP_NAME=cipher
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=[generate-a-64-character-random-string]

# --- LLM Providers (via LiteLLM) ---
ANTHROPIC_API_KEY=[YOUR_ANTHROPIC_API_KEY]
GROQ_API_KEY=[YOUR_GROQ_API_KEY]
OPENAI_API_KEY=[YOUR_OPENAI_API_KEY]
DEEPSEEK_API_KEY=[YOUR_DEEPSEEK_API_KEY]
XAI_API_KEY=[YOUR_XAI_API_KEY]
GOOGLE_API_KEY=[YOUR_GOOGLE_API_KEY]
PERPLEXITY_API_KEY=[YOUR_PERPLEXITY_API_KEY]
OLLAMA_BASE_URL=http://localhost:11434

# --- Default Model Routing ---
DEFAULT_MODEL=anthropic/claude-sonnet-4-20250514
REASONING_MODEL=anthropic/claude-sonnet-4-20250514
FAST_MODEL=groq/llama-3.3-70b-versatile
LOCAL_MODEL=ollama/llama3.3
CODE_MODEL=anthropic/claude-sonnet-4-20250514

# --- Database ---
DATABASE_URL=sqlite:///./data/cipher.db
CHROMA_PERSIST_DIR=./data/chroma

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=[YOUR_TELEGRAM_BOT_TOKEN]
TELEGRAM_ALLOWED_USERS=[YOUR_TELEGRAM_USER_ID]

# --- Redis (for Celery task queue) ---
REDIS_URL=redis://localhost:6379/0

# --- ElevenLabs (voice) ---
ELEVENLABS_API_KEY=[YOUR_ELEVENLABS_API_KEY]

# --- Payments ---
STRIPE_SECRET_KEY=[YOUR_STRIPE_SECRET_KEY]
STRIPE_WEBHOOK_SECRET=[YOUR_STRIPE_WEBHOOK_SECRET]
BTCPAY_URL=[YOUR_BTCPAY_URL]
BTCPAY_API_KEY=[YOUR_BTCPAY_API_KEY]

# --- Security ---
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440
